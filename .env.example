# Copy to .env and fill in. Never commit .env.
APP_ENV=dev
LOG_LEVEL=INFO

# Control plane
API_HOST=0.0.0.0
API_PORT=8000

# Datastores (docker-compose defaults)
POSTGRES_DSN=postgresql+psycopg://processiq:processiq@localhost:5432/processiq
MONGO_URI=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=processiq

# Object storage (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=processiq

# Messaging
NATS_URL=nats://localhost:4222

# Inference gateway (design Section 15.7)
MODEL_PROFILE=mock             # mock | local-6gb | server-24gb | cloud
INFERENCE_MODE=                # optional override: mock | hosted | local | vllm (empty = follow profile)
HOSTED_VLM_BASE_URL=           # OpenAI-compatible; VLM on local-6gb + Tier-2 fallback everywhere
HOSTED_VLM_API_KEY=
HOSTED_MODEL=gpt-4o-mini
VLLM_BASE_URL=http://localhost:8001/v1   # server-24gb: self-hosted vLLM (Qwen2.5-VL-7B AWQ)
VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct-AWQ
VLLM_API_KEY=
OCR_DEVICE=cpu                # cpu on Windows dev (GPU paddle conflicts with torch on Windows);
                              # cuda on the Linux 24GB server (paddle-gpu works cleanly there)
OCR_MKLDNN=0                  # keep 0 on Windows (paddle 3.7 PIR+oneDNN crash); 1 OK on Linux CPU
OCR_DET_MODEL=PP-OCRv5_server_det   # accurate (grounding snaps boxes to exact controls);
OCR_REC_MODEL=PP-OCRv5_server_rec   # swap to PP-OCRv5_mobile_* for ~3x faster but less precise CPU OCR
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True   # skip slow model-hoster connectivity check
OLLAMA_URL=http://localhost:11434        # offline experiments only, never the pipeline path
OLLAMA_MODEL=qwen2.5:3b

# OmniParser v2 (detection) — download microsoft/OmniParser-v2.0 into OMNIPARSER_WEIGHTS
OMNIPARSER_WEIGHTS=weights/omniparser
OMNIPARSER_BOX_THRESHOLD=0.05
OMNIPARSER_CAPTIONS=1          # 0 = skip Florence-2 captions (saves ~1GB VRAM on the 6GB box)

# Perception cache (sha256-keyed; Redis if REDIS_URL set, else file cache)
INFERENCE_CACHE_DIR=.cache/inference

# Snap VLM click-boxes onto exact pixels via full-image OCR of the target label (needs PaddleOCR).
# 1 = accurate boxes (slower on CPU, fast on GPU); 0 = use raw VLM boxes only (fast).
GROUND_BBOX=1

# Preload the OCR model at server boot (in the background) so the first request never waits.
# 1 = warm on startup; 0 = lazy-load on first use.
WARMUP_OCR=1

# Tenancy / security
DEFAULT_TENANT=demo
CONFIDENCE_THRESHOLD=0.75

